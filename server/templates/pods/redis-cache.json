{
  "id": "redis-cache",
  "version": "1.0.0",
  "name": "Redis Cache",
  "description": "Single-node Redis cache with an append-only persistent data volume.",
  "image": "docker.io/library/redis:7-alpine",
  "command": ["redis-server", "--appendonly", "yes", "--appendfsync", "everysec"],
  "ports": [
    {
      "host": 6379,
      "container": 6379,
      "protocol": "tcp"
    }
  ],
  "volumes": [
    {
      "host_path": "podorel-redis-cache-data",
      "container_path": "/data",
      "read_only": false
    }
  ],
  "environment": {},
  "secrets": [],
  "health_command": ["redis-cli", "ping"],
  "resource_limits": {
    "cpu": "0.75",
    "memory": "256MiB"
  },
  "restart_policy": "unless-stopped",
  "labels": {
    "io.podorel.template": "redis-cache"
  },
  "ui_notes": ["Cache data persists in the podorel-redis-cache-data volume; back up that volume before relying on it for important data."]
}
