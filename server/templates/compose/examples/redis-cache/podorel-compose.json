{
  "id": "example-redis-cache",
  "version": "1.0.0",
  "name": "Redis Cache Compose",
  "description": "Single Redis service compose stack with append-only persistence.",
  "source_path": "server/templates/compose/examples/redis-cache",
  "compose_files": ["docker-compose.yml"],
  "services": [
    {
      "name": "redis",
      "image": "docker.io/library/redis:7-alpine",
      "container_name": "podorel-compose-redis",
      "restart": "unless-stopped",
      "ports": ["${REDIS_PORT:-6379}:6379"]
    }
  ],
  "environment_files": [".env.example"],
  "required_files": [],
  "notes": [
    "Persists Redis data in the redis-data volume; back up that volume before relying on it for important data."
  ],
  "labels": {
    "io.podorel.example": "true"
  }
}
