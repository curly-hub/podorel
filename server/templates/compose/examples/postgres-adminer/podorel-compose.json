{
  "id": "example-postgres-adminer",
  "version": "1.0.0",
  "name": "Postgres and Adminer Compose",
  "description": "Database stack with Postgres storage and an Adminer web console for local development.",
  "source_path": "server/templates/compose/examples/postgres-adminer",
  "compose_files": ["docker-compose.yml"],
  "services": [
    {
      "name": "postgres",
      "image": "docker.io/library/postgres:16-alpine",
      "container_name": "podorel-compose-postgres",
      "restart": "unless-stopped",
      "ports": ["${POSTGRES_PORT:-5432}:5432"]
    },
    {
      "name": "adminer",
      "image": "docker.io/library/adminer:4",
      "container_name": "podorel-compose-adminer",
      "restart": "unless-stopped",
      "ports": ["${ADMINER_PORT:-8086}:8080"]
    }
  ],
  "environment_files": [".env.example"],
  "required_files": [],
  "notes": [
    "The example password is for development only. Change it before sharing the stack.",
    "Postgres data is persisted in the postgres-data named volume."
  ],
  "labels": {
    "io.podorel.example": "true"
  }
}
